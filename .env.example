# claude-recall Environment Configuration
# Copy this file to .env in your project directory or set these in your shell environment.
# Note: These are optional fallback settings. By default, claude-recall uses the
# active claude CLI session which requires no API keys or manual configuration.

# ------------------------------------------------------------------------------
# 1. Anthropic API (First Fallback)
# ------------------------------------------------------------------------------
# Used when the claude CLI is unavailable or fails.
# Requires the 'anthropic' Python package (installed by default during setup).
# Get a key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------------------
# 2. NVIDIA NIM / OpenAI-Compatible API (Second Fallback)
# ------------------------------------------------------------------------------
# Used when both the claude CLI and ANTHROPIC_API_KEY are unavailable or fail.
# Requires the 'openai' Python package.
# Example NIM setup (with an OpenAI-compatible endpoint like build.nvidia.com):
#   NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
#   OPENAI_API_KEY=nvapi-...
OPENAI_API_KEY=
NVIDIA_NIM_BASE_URL=
